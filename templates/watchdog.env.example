# watchdog.env.example
# Environment configuration for the Hendrik Watchdog
# Copy to ~/.openclaw/env/watchdog.env and set values before deploying.
# NEVER commit the real .env file — only this example.

# ── Timing ────────────────────────────────────────────────────────────────────
# How often launchd fires the watchdog (seconds). Must match StartInterval in plist.
WATCHDOG_INTERVAL_S=300

# ── Thresholds ────────────────────────────────────────────────────────────────
# Model call duration that triggers a WARN log line (milliseconds)
WARN_MS=45000

# Model call duration that triggers a HARD log line and forces failover (milliseconds)
HARD_MS=90000

# Equivalent in seconds for model_router.py timeout enforcement
HARD_S=90

# Recovery wait after kickstarting the gateway before re-probing (seconds)
WATCHDOG_WAIT_SECS=15

# ── Paths ─────────────────────────────────────────────────────────────────────
# Runtime state directory — must match STATE_DIR in hendrik_watchdog.sh
STATE_DIR=~/.openclaw/watchdog

# ── Alert target ─────────────────────────────────────────────────────────────
# Phone number to receive RECOVERY/FAIL alerts via openclaw channels send
WATCHDOG_TARGET=+1XXXXXXXXXX

# ── Test isolation ────────────────────────────────────────────────────────────
# Set to "1" during test runs to prevent model_router.py from writing model_state.json.
# MUST be set in all test harnesses. Never set in production.
# TEST_MODE=1
