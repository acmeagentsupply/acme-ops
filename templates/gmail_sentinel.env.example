# ~/.openclaw/env/gmail_sentinel.env  (DO NOT COMMIT REAL VALUES)
# chmod 600 ~/.openclaw/env/gmail_sentinel.env

# Token used for gog webhook auth (?token=...) and OpenClaw hooks token validation
HOOKS_TOKEN="REPLACE_ME"

# Public base URL for the Tailscale funnel host (no path, no query)
# Example: https://agentmacbook.tailXXXX.ts.net
EXTERNAL_URL_BASE="https://REPLACE_ME.tailXXXX.ts.net"

# Path exposed on the funnel routing to your local 8788
GMAIL_PATH="/gmail-pubsub"

# Local listen port for gog watcher
GMAIL_PORT="8788"

# Optional: OpenClaw gateway URL (local)
GATEWAY_URL="http://127.0.0.1:18789"

# Optional: account email for watcher/diagnostics
GMAIL_ACCOUNT="hendrik.homarus@gmail.com"
