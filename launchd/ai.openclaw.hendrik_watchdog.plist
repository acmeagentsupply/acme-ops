<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>OPENCLAW_LANE</key>
		<string>background</string>
		<key>WATCHDOG_TARGET</key>
		<string>+19787606557</string>
		<key>WATCHDOG_WAIT_SECS</key>
		<string>15</string>
	</dict>
	<key>KeepAlive</key>
	<false/>
	<key>Label</key>
	<string>ai.openclaw.hendrik_watchdog</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>-lc</string>
		<string>/Users/AGENT/.openclaw/watchdog/hendrik_watchdog.sh</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardErrorPath</key>
	<string>/Users/AGENT/.openclaw/watchdog/launchd.err.log</string>
	<key>StandardOutPath</key>
	<string>/Users/AGENT/.openclaw/watchdog/launchd.out.log</string>
	<key>StartInterval</key>
	<integer>300</integer>
</dict>
</plist>
